OPENAI_API_KEY=sk-your-key-here
# Optional for third-party OpenAI-compatible API gateways:
# OPENAI_BASE_URL=https://api.example.com/v1

# Required only when running scripts/track_a_eval.py --provider anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional, only set if you route through an Anthropic-compatible gateway:
# ANTHROPIC_BASE_URL=https://api.example.com
# ChatAnywhere examples:
#   Germany / outside China: ANTHROPIC_BASE_URL=https://api.chatanywhere.org/v1
#   Mainland China:          ANTHROPIC_BASE_URL=https://api.chatanywhere.tech/v1

# Optional GWDG/SAIA OpenAI-compatible API for Track B generation:
GWDG_API_KEY=your-gwdg-saia-key-here
GWDG_BASE_URL=https://chat-ai.academiccloud.de/v1
